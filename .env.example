# EPA API 設定
# 請在 .env 檔案中設定實際的 API 金鑰（.env 不會被提交到 Git）
EPA_API_KEY=your_api_key_here

# 座標參考系統 (CRS) 設定
# EPSG:4326 - WGS84 (經緯度，全球通用)
# EPSG:3826 - TWD97 / TM2 zone 121 (台灣常用座標系統)
# EPSG:3825 - TWD97 / TM2 zone 119
DEFAULT_CRS=EPSG:4326
TAIWAN_CRS=EPSG:3826

# 輸出檔案座標系統
OUTPUT_CRS=EPSG:4326

# 台北車站座標 (WGS84)
TAIPEI_STATION_LAT=25.0478
TAIPEI_STATION_LON=121.5170
